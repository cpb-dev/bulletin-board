# Copy to .env.local for development; set the same vars in Vercel.

# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Make it yours — this is the name shown everywhere in the app.
NEXT_PUBLIC_APP_NAME="Our Little Board"

# Phone notifications (optional). Generate a keypair with:
#   npx web-push generate-vapid-keys
# Put the PUBLIC key here (and in Vercel). The PRIVATE key goes into the
# Supabase edge function secrets only — never in the web app. Full steps
# in docs/NOTIFICATIONS.md.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
