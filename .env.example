# Copy to .env.local for development; set the same vars in Vercel.

# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Make it yours — this is the name shown everywhere in the app.
NEXT_PUBLIC_APP_NAME="Our Little Board"

# Phone notifications (optional) — all configurable from a phone via the
# Vercel/Supabase dashboards. Full steps in docs/NOTIFICATIONS.md.
#
# Public VAPID key — safe to expose, used by the browser to subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
#
# Server-only (set in Vercel, NEVER prefixed NEXT_PUBLIC). The /api/notify
# route uses these to send pushes; the webhook secret authenticates the
# Supabase Database Webhook that calls the route.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NOTIFY_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
